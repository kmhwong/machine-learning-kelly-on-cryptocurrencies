def plot_aggregate(fold_metrics: list[dict], args) -> None:
    fig = plt.figure(figsize=(16, 10))
    gs  = gridspec.GridSpec(3, 2, hspace=0.45, wspace=0.35)

    # ---- 1. Equity curves per fold ----
    ax1 = fig.add_subplot(gs[0, :])
    ax1.set_title(f"Out-of-Sample Equity Curves — {args.symbol} {args.interval}",
                  fontsize=13)
    cmap = plt.cm.tab10
    for i, m in enumerate(fold_metrics):
        df  = m['df']
        pv  = df['portfolio_value'] / df['portfolio_value'].iloc[0] * 100  # index to 100
        ax1.plot(df['close_dt'], pv, lw=1.5, color=cmap(i), label=m['label'])
    ax1.axhline(100, color='black', lw=0.8, linestyle='--')
    ax1.set_ylabel('Indexed Value (start=100)')
    ax1.legend(fontsize=8, ncol=min(len(fold_metrics), 5))

    # ---- 2. ROI vs B&H bar chart ----
    ax2 = fig.add_subplot(gs[1, 0])
    x    = np.arange(len(fold_metrics))
    rois = [m['roi']    for m in fold_metrics]
    bhs  = [m['bh_roi'] for m in fold_metrics]
    ax2.bar(x - 0.2, rois, 0.4, label='Strategy', color='royalblue', alpha=0.85)
    ax2.bar(x + 0.2, bhs,  0.4, label='B&H',       color='grey',      alpha=0.6)
    ax2.axhline(0, color='black', lw=0.8)
    ax2.set_xticks(x)
    ax2.set_xticklabels([m['label'] for m in fold_metrics], fontsize=8)
    ax2.set_title('ROI per Fold vs Buy & Hold')
    ax2.set_ylabel('%')
    ax2.legend(fontsize=8)

    # ---- 3. Sharpe per fold ----
    ax3 = fig.add_subplot(gs[1, 1])
    sharpes = [m['sharpe'] for m in fold_metrics]
    colours = ['seagreen' if s > 0 else 'crimson' for s in sharpes]
    ax3.bar(x, sharpes, color=colours, alpha=0.85)
    ax3.axhline(0, color='black', lw=0.8)
    ax3.set_xticks(x)
    ax3.set_xticklabels([m['label'] for m in fold_metrics], fontsize=8)
    ax3.set_title('Annualised Sharpe per Fold')
    ax3.set_ylabel('Sharpe')

    # ---- 4. p_conservative distribution (last fold) ----
    ax4 = fig.add_subplot(gs[2, 0])
    last_test = fold_metrics[-1]['df']
    breakeven = args.loss / (args.gain + args.loss)
    ax4.hist(last_test['p_conservative'].dropna(), bins=40,
             color='darkorange', alpha=0.75, label='p_conservative')
    ax4.axvline(breakeven,              color='red',   linestyle='--', label='Breakeven')
    ax4.axvline(breakeven + args.min_edge, color='green', linestyle='--', label='Min-edge threshold')
    ax4.set_title('p_conservative Distribution (last fold)')
    ax4.set_xlabel('Probability')
    ax4.legend(fontsize=8)

    # ---- 5. Max drawdown per fold ----
    ax5 = fig.add_subplot(gs[2, 1])
    dds = [m['max_dd'] for m in fold_metrics]
    ax5.bar(x, dds, color='crimson', alpha=0.7)
    ax5.set_xticks(x)
    ax5.set_xticklabels([m['label'] for m in fold_metrics], fontsize=8)
    ax5.set_title('Max Drawdown per Fold')
    ax5.set_ylabel('%')

    plt.savefig('wf_results.png', dpi=150)
    log.info("Walk-forward results plot saved → wf_results.png")
    plt.show()


# ===========================================================================
# SUMMARY TABLE
# ===========================================================================

def print_summary(fold_metrics: list[dict]) -> None:
    rois    = [m['roi']    for m in fold_metrics]
    bhs     = [m['bh_roi'] for m in fold_metrics]
    sharpes = [m['sharpe'] for m in fold_metrics if not np.isnan(m['sharpe'])]
    dds     = [m['max_dd'] for m in fold_metrics]

    log.info("=" * 65)
    log.info("WALK-FORWARD SUMMARY")
    log.info("=" * 65)
    log.info(f"  Folds completed   : {len(fold_metrics)}")
    log.info(f"  Mean ROI/fold     : {np.mean(rois):+.2f}% ± {np.std(rois):.2f}%")
    log.info(f"  Mean B&H/fold     : {np.mean(bhs):+.2f}%")
    log.info(f"  Alpha (mean)      : {np.mean(rois) - np.mean(bhs):+.2f}%")
    log.info(f"  Mean Sharpe       : {np.mean(sharpes):.3f}")
    log.info(f"  Mean Max Drawdown : {np.mean(dds):.2f}%")
    log.info(f"  Profitable folds  : {sum(r > 0 for r in rois)}/{len(fold_metrics)}")
    log.info(f"  Beat B&H folds    : {sum(r > b for r, b in zip(rois, bhs))}/{len(fold_metrics)}")

    # t-test: is mean ROI significantly above zero?
    if len(rois) >= 3:
        t, p = stats.ttest_1samp(rois, 0)
        log.info(f"  t-test ROI > 0    : t={t:.3f}  p={p:.4f}  "
                 f"{'✓ SIGNIFICANT (p<0.10)' if p < 0.10 else '✗ not significant'}")

    log.info("=" * 65)


