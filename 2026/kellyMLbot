if __name__ == '__main__':
    parser = argparse.ArgumentParser(description="Kelly Bot v3 — XGBoost + Calibration")

    # Market
    parser.add_argument('--symbol',        type=str,   default='BTCUSDT')
    parser.add_argument('--interval',      type=str,   default='1h')
    parser.add_argument('--mode',          type=str,
                        choices=['backtest', 'importance'],
                        default='backtest',
                        help='backtest: full WF run | importance: feature importance only')

    # Strategy
    parser.add_argument('--gain',          type=float, default=0.025)
    parser.add_argument('--loss',          type=float, default=0.010)
    parser.add_argument('--kelly-mult',    type=float, default=0.5,
                        help='Fractional Kelly multiplier')
    parser.add_argument('--min-edge',      type=float, default=0.03,
                        help='Min probability edge above breakeven to trade')

    # Data
    parser.add_argument('--lookback-bars', type=int,   default=8000,
                        help='Total bars to download (more = better ML training)')
    parser.add_argument('--horizon-bars',  type=int,   default=24,
                        help='Max bars to resolve a gain/loss outcome')

    # Walk-forward
    parser.add_argument('--wf-splits',    type=int,   default=5)
    parser.add_argument('--wf-test-pct',  type=float, default=0.12,
                        help='Fraction of available data per test fold')
    parser.add_argument('--train-min',    type=int,   default=800,
                        help='Minimum training bars before first fold')

    # Execution
    parser.add_argument('--deadband',     type=float, default=0.10)

    args = parser.parse_args()

    # ---- Fetch raw data ----
    raw_df = fetch_binance_klines(args.symbol, args.interval, args.lookback_bars)

    if args.mode == 'importance':
        # Quick mode: fit one model on all data, show feature importance
        feat_df = build_features(
            label_outcomes(raw_df, args.gain, args.loss, args.horizon_bars)
        ).dropna(subset=FEATURE_COLS + ['outcome'])

        X = feat_df[FEATURE_COLS].values
        y = feat_df['outcome'].values.astype(int)
        split = int(len(X) * 0.8)
        md = fit_model(X[:split], y[:split], X[split:], y[split:], args)
        plot_feature_importance(md)

    else:  # backtest (full walk-forward)
        fold_metrics = walk_forward(raw_df, args, plot_calibration=True)

        if not fold_metrics:
            log.error("No folds completed — try increasing --lookback-bars or reducing --train-min")
        else:
            # Feature importance from last fold's model
            plot_feature_importance(fold_metrics[-1]['model_dict'])

            # Aggregate charts
            plot_aggregate(fold_metrics, args)

            # Summary stats
            print_summary(fold_metrics)
