def plot_feature_importance(model_dict: dict) -> None:
    base  = model_dict['base']
    imp   = base.feature_importances_
    idx   = np.argsort(imp)[::-1]
    names = [FEATURE_COLS[i] for i in idx]
    vals  = imp[idx]

    fig, ax = plt.subplots(figsize=(10, 6))
    colours = plt.cm.RdYlGn(np.linspace(0.2, 0.9, len(vals)))
    ax.barh(names[::-1], vals[::-1], color=colours[::-1])
    ax.set_xlabel('XGBoost Feature Importance (gain)')
    ax.set_title('Feature Importance — Base XGBoost')
    plt.tight_layout()
    plt.savefig('feature_importance.png', dpi=150)
    log.info("Feature importance plot saved → feature_importance.png")
    plt.show()


